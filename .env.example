# Server
PORT=3000
BASE_URL=https://your-service.com

# SendPulse App Directory
SP_APP_ID=your_sp_app_id
SP_APP_SECRET=your_sp_app_secret

# Slack OAuth App
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

# Database (SQLite path — dev uses /tmp/sp_slack.db, prod uses ./data/sp_slack.db)
DB_PATH=./data/sp_slack.db

# Session secret (random string)
SESSION_SECRET=change_me_random_32_chars
